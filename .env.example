# Required
DATABASE_URL=postgresql://user:password@host/dbname
JWT_SECRET=your-secret-key-at-least-32-characters-long
NEXT_PUBLIC_URL=http://localhost:3000

# AWS SES (email delivery)
SES_ACCESS_KEY_ID=your-ses-access-key
SES_SECRET_ACCESS_KEY=your-ses-secret-key

# AgentPlane (AI personalization)
AGENTPLANE_API_URL=https://your-agentplane-instance
AGENTPLANE_API_KEY=your-agentplane-api-key

# Required in production/staging (unauthenticated cron access is only allowed in dev)
CRON_SECRET=your-cron-secret

# Optional
# SES_NOTIFICATION_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:topic-name
# ENVIRONMENT=dev
# AWS_SES_REGION=us-east-1
# ALLOWED_DCR_DOMAINS=claude.ai,chatgpt.com,localhost,127.0.0.1
